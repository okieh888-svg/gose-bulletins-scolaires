{% extends 'base.html.twig' %}
{% block title %}Saisie notes — {{ matiere.nom }}{% endblock %}
{% block body %}
<h1>{{ matiere.nom }} — {{ classe.nom }}</h1>
<p class="page-subtitle">{{ periode.nom }} · Saisissez une nouvelle note (elle s'ajoute à l'historique de l'élève pour cette matière/période).</p>

<div class="card">
    <form method="post" class="formulaire-classique">
        <label for="type_evaluation">Type d'évaluation</label>
        <select name="type_evaluation" id="type_evaluation">
            <option value="Devoir">Devoir</option>
            <option value="Interrogation">Interrogation</option>
            <option value="Composition">Composition</option>
        </select>

        <table class="card-table" style="margin-top:1rem;">
            <thead>
                <tr><th>Élève</th><th>Notes existantes</th><th>Nouvelle note /20</th></tr>
            </thead>
            <tbody>
            {% for eleve in classe.eleves %}
                <tr>
                    <td>{{ eleve.nomComplet }}</td>
                    <td>
                        {% for note in notesParEleve[eleve.id] %}
                            <span class="badge badge-gris">{{ note.valeur }} ({{ note.typeEvaluation }})</span>
                        {% else %}
                            <span class="page-subtitle">Aucune note</span>
                        {% endfor %}
                    </td>
                    <td><input type="number" step="0.25" min="0" max="20" name="notes[{{ eleve.id }}]"></td>
                </tr>
            {% endfor %}
            </tbody>
        </table>

        <input type="hidden" name="_token" value="{{ csrf_token('saisie_notes') }}">
        <div class="form-actions">
            <button class="btn" type="submit">Enregistrer les notes</button>
            <a class="btn btn-secondaire" href="{{ path('app_enseignant_classe', {id: classe.id, periode: periode.id}) }}">Retour à la classe</a>
        </div>
    </form>
</div>
{% endblock %}
