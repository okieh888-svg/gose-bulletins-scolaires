<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Bulletin {{ bulletin.eleve.nomComplet }}</title>
<style>
    body { font-family: "DejaVu Sans", sans-serif; font-size: 11px; color: #1c2733; margin: 0; padding: 20px 28px; }
    .entete { display: table; width: 100%; border-bottom: 3px solid #0b3d63; padding-bottom: 10px; margin-bottom: 14px; }
    .entete .logo { display: table-cell; width: 70px; }
    .logo-cercle { width: 60px; height: 60px; border-radius: 50%; border: 2px solid #0b3d63; text-align: center; font-size: 7px; font-weight: bold; color: #0b3d63; padding-top: 18px; overflow: hidden; }
    .logo-cercle img { width: 60px; height: 60px; object-fit: cover; border-radius: 50%; }
    .entete .etab { display: table-cell; text-align: right; vertical-align: middle; }
    .etab .nom { font-size: 15px; font-weight: bold; color: #0b3d63; }
    .titre { text-align: center; margin: 14px 0; }
    .titre h1 { font-size: 16px; color: #0b3d63; margin: 0; }
    .titre .sous { font-size: 10px; color: #667085; }
    .infos { width: 100%; margin-bottom: 14px; }
    .infos td { vertical-align: top; width: 50%; padding: 2px 0; }
    table.notes { width: 100%; border-collapse: collapse; margin-bottom: 14px; }
    table.notes th, table.notes td { border: 1px solid #d9dee3; padding: 5px 7px; font-size: 10.5px; text-align: left; }
    table.notes th { background: #eef2f5; color: #0b3d63; }
    .synthese { width: 100%; margin-top: 10px; }
    .synthese td { width: 33.3%; text-align: center; border: 1px solid #d9dee3; padding: 8px; }
    .synthese .valeur { font-size: 16px; font-weight: bold; color: #0b3d63; }
    .synthese .label { font-size: 9px; color: #667085; }
    .signatures { width: 100%; margin-top: 40px; }
    .signatures td { width: 50%; text-align: center; font-size: 10px; padding-top: 30px; border-top: 1px solid #1c2733; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 9px; background: #eef2f5; }
    .footer-note { margin-top: 24px; font-size: 8px; color: #667085; text-align: center; }
    .verif-bloc { display: table; width: 100%; margin-top: 20px; padding-top: 10px; border-top: 1px dashed #d9dee3; }
    .verif-bloc .qr { display: table-cell; width: 70px; }
    .verif-bloc .texte { display: table-cell; vertical-align: middle; font-size: 8.5px; color: #667085; padding-left: 10px; }
    .verif-bloc .texte strong { color: #1c2733; }
    .verif-bloc .texte .code { font-family: monospace; font-size: 8px; }
</style>
</head>
<body>
    <div class="entete">
        <div class="logo"><div class="logo-cercle">{% if logoDataUri %}<img src="{{ logoDataUri }}" alt="Logo MENFOP">{% else %}LOGO<br>ÉTAB.{% endif %}</div></div>
        <div class="etab">
            <div class="nom">{{ bulletin.eleve.classe.etablissement.nom }}</div>
            <div>{{ bulletin.eleve.classe.etablissement.ville }} — République de Djibouti</div>
            <div>MENFOP — Ministère de l'Éducation Nationale et de la Formation Professionnelle</div>
        </div>
    </div>

    <div class="titre">
        <h1>BULLETIN SCOLAIRE — {{ bulletin.periode.nom|upper }}</h1>
        <div class="sous">Année scolaire {{ bulletin.periode.anneeScolaire }}</div>
    </div>

    <table class="infos">
        <tr>
            <td>
                <strong>{{ bulletin.eleve.nomComplet }}</strong><br>
                Matricule : {{ bulletin.eleve.matricule }}<br>
                Né(e) le {{ bulletin.eleve.dateNaissance|date('d/m/Y') }}
            </td>
            <td>
                Classe : {{ bulletin.eleve.classe.nom }} ({{ bulletin.eleve.classe.niveau }})<br>
                Statut du bulletin : <span class="badge">{{ bulletin.statut.libelle }}</span><br>
                Édité le {{ "now"|date('d/m/Y') }}
            </td>
        </tr>
    </table>

    <table class="notes">
        <thead>
            <tr><th>Matière</th><th>Coefficient</th><th>Moyenne /20</th><th>Moyenne × coef.</th><th>Appréciation</th></tr>
        </thead>
        <tbody>
        {% for ligne in bulletin.lignes %}
            <tr>
                <td>{{ ligne.matiere.nom }}</td>
                <td>{{ ligne.coefficient }}</td>
                <td>{{ ligne.moyenne }}</td>
                <td>{{ ligne.moyenneCoefficientee }}</td>
                <td>{{ ligne.appreciation }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <table class="synthese">
        <tr>
            <td><div class="valeur">{{ bulletin.moyenneGenerale ?? '—' }}/20</div><div class="label">MOYENNE GÉNÉRALE</div></td>
            <td><div class="valeur">{{ bulletin.rangAffiche }}</div><div class="label">RANG DE CLASSE</div></td>
            <td><div class="valeur">{{ bulletin.appreciationGenerale ?? '—' }}</div><div class="label">APPRÉCIATION</div></td>
        </tr>
    </table>

    <table class="signatures">
        <tr>
            <td>Signature de l'enseignant<br>{{ bulletin.valideParEnseignant ? bulletin.valideParEnseignant.nomComplet : '' }}</td>
            <td>Signature du chef d'établissement<br>{{ bulletin.publieParProviseur ? bulletin.publieParProviseur.nomComplet : '' }}</td>
        </tr>
    </table>

    {% if qrCodeDataUri %}
    <div class="verif-bloc">
        <div class="qr"><img src="{{ qrCodeDataUri }}" width="65" height="65"></div>
        <div class="texte">
            <strong>Vérification d'authenticité</strong><br>
            Scannez ce QR code ou consultez :<br>
            {{ verificationUrl }}<br>
            Code : <span class="code">{{ bulletin.codeVerification }}</span>
        </div>
    </div>
    {% endif %}

    <div class="footer-note">
        Document généré par GOSE — Prototype de démonstration technique. Données 100% fictives, aucun mineur réel.
    </div>
</body>
</html>
