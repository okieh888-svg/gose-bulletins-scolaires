<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>{{ ("كشف النقاط " ~ bulletin.eleve.nomComplet)|ar_glyphs }}</title>
<style>
    /*
     * Variante arabe (RTL) du bulletin — démonstration du bilinguisme requis
     * au Lot 8 (arabisation) du TDR. dompdf gère le rendu RTL de base ; pour
     * une qualité typographique optimale en production, embarquer une police
     * arabe dédiée (ex: Amiri, Noto Naskh Arabic) via $options->setFontDir().
     */
    body { font-family: "DejaVu Sans", sans-serif; font-size: 11px; color: #1c2733; margin: 0; padding: 20px 28px; direction: rtl; }
    .entete { display: table; width: 100%; border-bottom: 3px solid #0b3d63; padding-bottom: 10px; margin-bottom: 14px; }
    .entete .logo { display: table-cell; width: 70px; }
    .logo-cercle { width: 60px; height: 60px; border-radius: 50%; border: 2px solid #0b3d63; text-align: center; font-size: 7px; font-weight: bold; color: #0b3d63; padding-top: 18px; overflow: hidden; }
    .logo-cercle img { width: 60px; height: 60px; object-fit: cover; border-radius: 50%; }
    .entete .etab { display: table-cell; text-align: left; vertical-align: middle; }
    .etab .nom { font-size: 15px; font-weight: bold; color: #0b3d63; }
    .titre { text-align: center; margin: 14px 0; }
    .titre h1 { font-size: 16px; color: #0b3d63; margin: 0; }
    .titre .sous { font-size: 10px; color: #667085; }
    .infos { width: 100%; margin-bottom: 14px; }
    .infos td { vertical-align: top; width: 50%; padding: 2px 0; }
    table.notes { width: 100%; border-collapse: collapse; margin-bottom: 14px; }
    table.notes th, table.notes td { border: 1px solid #d9dee3; padding: 5px 7px; font-size: 10.5px; text-align: right; }
    table.notes th { background: #eef2f5; color: #0b3d63; }
    .synthese { width: 100%; margin-top: 10px; }
    .synthese td { width: 33.3%; text-align: center; border: 1px solid #d9dee3; padding: 8px; }
    .synthese .valeur { font-size: 16px; font-weight: bold; color: #0b3d63; }
    .synthese .label { font-size: 9px; color: #667085; }
    .signatures { width: 100%; margin-top: 40px; }
    .signatures td { width: 50%; text-align: center; font-size: 10px; padding-top: 30px; border-top: 1px solid #1c2733; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 9px; background: #eef2f5; }
    .footer-note { margin-top: 24px; font-size: 8px; color: #667085; text-align: center; }
    .verif-bloc { display: table; width: 100%; margin-top: 20px; padding-top: 10px; border-top: 1px dashed #d9dee3; }
    .verif-bloc .qr { display: table-cell; width: 70px; }
    .verif-bloc .texte { display: table-cell; vertical-align: middle; font-size: 8.5px; color: #667085; padding-right: 10px; }
    .verif-bloc .texte strong { color: #1c2733; }
    .verif-bloc .texte .code { font-family: monospace; font-size: 8px; direction: ltr; display: inline-block; }
</style>
</head>
<body>
    <div class="entete">
        <div class="etab">
            <div class="nom">{{ bulletin.eleve.classe.etablissement.nom }}</div>
            <div>{{ (bulletin.eleve.classe.etablissement.ville ~ " — جمهورية جيبوتي")|ar_glyphs }}</div>
            <div>{{ "وزارة التربية الوطنية والتكوين المهني"|ar_glyphs }}</div>
        </div>
        <div class="logo"><div class="logo-cercle">{% if logoDataUri %}<img src="{{ logoDataUri }}" alt="شعار MENFOP">{% else %}{{ "شعار"|ar_glyphs }}<br>{{ "المؤسسة"|ar_glyphs }}{% endif %}</div></div>
    </div>

    <div class="titre">
        <h1>{{ ("كشف النقاط — " ~ bulletin.periode.nom)|ar_glyphs }}</h1>
        <div class="sous">{{ ("السنة الدراسية " ~ bulletin.periode.anneeScolaire)|ar_glyphs }}</div>
    </div>

    <table class="infos">
        <tr>
            <td>
                <strong>{{ (bulletin.eleve.nomArabe ?? bulletin.eleve.nomComplet)|ar_glyphs }}</strong><br>
                {{ ("رقم التسجيل : " ~ bulletin.eleve.matricule)|ar_glyphs }}<br>
                {{ ("تاريخ الازدياد : " ~ bulletin.eleve.dateNaissance|date('d/m/Y'))|ar_glyphs }}
            </td>
            <td>
                {{ ("القسم : " ~ bulletin.eleve.classe.nom)|ar_glyphs }}<br>
                {{ "حالة الكشف :"|ar_glyphs }} <span class="badge">{{ bulletin.statut.libelle }}</span><br>
                {{ ("تاريخ الإصدار : " ~ ("now"|date('d/m/Y')))|ar_glyphs }}
            </td>
        </tr>
    </table>

    <table class="notes">
        <thead>
            <tr>
                <th>{{ "المادة"|ar_glyphs }}</th>
                <th>{{ "المعامل"|ar_glyphs }}</th>
                <th>{{ "المعدل /20"|ar_glyphs }}</th>
                <th>{{ "المعدل × المعامل"|ar_glyphs }}</th>
                <th>{{ "الملاحظة"|ar_glyphs }}</th>
            </tr>
        </thead>
        <tbody>
        {% for ligne in bulletin.lignes %}
            <tr>
                <td>{{ (ligne.matiere.nomArabe ?? ligne.matiere.nom)|ar_glyphs }}</td>
                <td>{{ ligne.coefficient }}</td>
                <td>{{ ligne.moyenne }}</td>
                <td>{{ ligne.moyenneCoefficientee }}</td>
                <td>{{ (appreciationsArabeLignes[ligne.id] ?? ligne.appreciation)|ar_glyphs }}</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <table class="synthese">
        <tr>
            <td><div class="valeur">{{ bulletin.moyenneGenerale ?? '—' }}/20</div><div class="label">{{ "المعدل العام"|ar_glyphs }}</div></td>
            <td><div class="valeur">{{ bulletin.rangAffiche }}</div><div class="label">{{ "الرتبة داخل القسم"|ar_glyphs }}</div></td>
            <td><div class="valeur">{{ (appreciationGeneraleArabe ?? bulletin.appreciationGenerale ?? '—')|ar_glyphs }}</div><div class="label">{{ "الملاحظة العامة"|ar_glyphs }}</div></td>
        </tr>
    </table>

    <table class="signatures">
        <tr>
            <td>{{ "توقيع الأستاذ(ة)"|ar_glyphs }}<br>{{ bulletin.valideParEnseignant ? bulletin.valideParEnseignant.nomComplet : '' }}</td>
            <td>{{ "توقيع مدير(ة) المؤسسة"|ar_glyphs }}<br>{{ bulletin.publieParProviseur ? bulletin.publieParProviseur.nomComplet : '' }}</td>
        </tr>
    </table>

    {% if qrCodeDataUri %}
    <div class="verif-bloc">
        <div class="texte">
            <strong>{{ "التحقق من صحة الوثيقة"|ar_glyphs }}</strong><br>
            {{ "امسح رمز QR أو زر الرابط التالي:"|ar_glyphs }}<br>
            {{ verificationUrl }}<br>
            {{ "الرمز :"|ar_glyphs }} <span class="code">{{ bulletin.codeVerification }}</span>
        </div>
        <div class="qr"><img src="{{ qrCodeDataUri }}" width="65" height="65"></div>
    </div>
    {% endif %}

    <div class="footer-note">
        {{ "وثيقة صادرة عن نظام GOSE — نموذج تجريبي للعرض التقني. بيانات وهمية بالكامل، لا يوجد أي قاصر حقيقي."|ar_glyphs }}
    </div>
</body>
</html>
